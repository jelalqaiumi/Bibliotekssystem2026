<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="9.0.9" />
  </ItemGroup>

  <!-- Exclude the test project folder from this build -->
  <ItemGroup>
    <Compile Remove="LibrarySystem.Tests\**" />
    <Content Remove="LibrarySystem.Tests\**" />
    <EmbeddedResource Remove="LibrarySystem.Tests\**" />
    <None Remove="LibrarySystem.Tests\**" />
  </ItemGroup>

</Project>
